{
  "id": "com.vido.playlists",
  "name": "playlists",
  "displayName": "Playlists",
  "version": "1.0.0",
  "description": "Playlist creation, management, and playback for Vido — create playlists, drag-and-drop files, shuffle, and control playback order.",
  "author": "Vido",
  "license": "MIT",
  "entryPoint": "PlaylistPlugin.dll",
  "pluginClass": "PlaylistPlugin.PlaylistPlugin",
  "minVidoVersion": "0.8.0",
  "tags": ["playlist", "queue", "playback"],
  "icon": "Assets/Playlist-plugin.png",
  "contributes": {
    "sidebar": [
      {
        "id": "playlist-sidebar",
        "title": "Playlists",
        "icon": "Assets/Icons/sidebar-icon.png",
        "order": 100
      }
    ],
    "contextMenu": [
      {
        "id": "add-to-playlist",
        "label": "Add to Playlist",
        "fileExtensions": [".mp4", ".avi", ".mkv", ".mov", ".wmv", ".flv", ".webm"],
        "order": 200
      }
    ],
    "statusBar": [
      {
        "id": "playlist-status",
        "name": "Playlist Status",
        "position": "left",
        "order": 100
      }
    ],
    "settings": [
      {
        "id": "autoSave",
        "type": "boolean",
        "default": false,
        "title": "Automatically Save Playlists",
        "description": "When enabled, any change to a playlist is automatically saved. If the playlist has never been saved, you will be prompted to choose a save location.",
        "section": "General"
      }
    ]
  }
}
